root = true

# Default settings for all files
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# source files
[*.{cs,csx}]
indent_style = space
indent_size = 4

# JSON, YAML, and XML config files
[*.{json,jsonc,yml,yaml}]
indent_style = space
indent_size = 2

# Project and build files
[*.{sln,slnx,csproj,props,targets}]
indent_style = space
indent_size = 2

# Markdown - preserve trailing whitespace for line breaks
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf

# Docker
[{Dockerfile,*.dockerfile,docker-compose*.yml}]
indent_style = space
indent_size = 2

# GitHub Actions
[.github/**/*.yml]
indent_style = space
indent_size = 2
